{
  "name": "ji-type-schema",
  "version": "1.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "smoke": "pnpm build && node examples/smoke.mjs",
    "release:patch": "npm version patch && pnpm build && npm publish --access public",
    "release:minor": "npm version minor && pnpm build && npm publish --access public",
    "release:major": "npm version major && pnpm build && npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "sideEffects": false,
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
